    "version": "0.2.0",
    "configurations": [
        




        {
            "name": "Python Debugger: Debug features.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/hmmer_features/features.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/scripts/hmmer_features",
            "args": ["-d", "${workspaceFolder}/scripts/hmmer_features/testing/dummy_testing/hmmer_results", "-o", "${workspaceFolder}/scripts/hmmer_features/testing/hmmer_pics/"]
        },

        {
            "name": "Python Debugger: Debug json_to_tab.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/HMMER_api_json_to_tab/json_to_tab.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/scripts/HMMER_api_json_to_tab",
            "args": ["-d", "${workspaceFolder}/scripts/HMMER_api_json_to_tab/test_2"]
        },
    ]
}